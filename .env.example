# Telegram bot
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=YourBotUsername

# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Groq AI (proposal parsing)
GROQ_API_KEY=sk-your_groq_api_key_here

# TON relayer wallet — use testnet addresses (0Q/kQ) when TON_NETWORK=testnet
BOT_WALLET_ADDRESS=0Q...
BOT_MNEMONIC="word1 word2 ... word24"

# testnet | mainnet (defaults to testnet if unset)
TON_NETWORK=testnet

# CORS — frontend dev server origin(s), comma-separated
FRONTEND_ORIGIN=http://localhost:8080,http://localhost:5173
